Options -Indexes

RewriteEngine On

# Não define um RewriteBase fixo. Deixa o Apache resolver pelo caminho físico.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redireciona para o index.php que está na mesma pasta deste .htaccess
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]